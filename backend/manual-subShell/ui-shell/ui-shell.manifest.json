{
  "manifestVersion": 3,
  "kind": "subShell",
  "id": "manual",
  "hostRef": "main",
  "hostApiVersion": "1.0.0",
  "hostCompat": ">=1.0.0 <2.0.0",
  "version": "0.1.0",
  "title": "Manual",
  "description": "OpenSphere Manual subShell backed by the OAA Manual Registry.",
  "entry": "ui-shell.plugin.js",
  "entrySha256": "7136d6eb75f98582584304c28dc61417cc38d9b39198bb3b4750f7fe6d11f11a",
  "shellCompat": ">=0.2.0 <0.9.0",
  "sdkVersion": "0.3.6",
  "permissions": [
    "page:register",
    "api:proxy",
    "nav:contribute",
    "manual:contribute"
  ],
  "nav": {
    "band": "구축 Build",
    "label": "Manual"
  },
  "designSystem": "clarity",
  "apiBase": "/api/plugins/manual",
  "renderMode": "esm",
  "contributions": {
    "page": {
      "enabled": true
    },
    "navigation": {
      "enabled": true,
      "mode": "runtime"
    },
    "api": {
      "enabled": true,
      "basePath": "/api/manual"
    },
    "cli": {
      "enabled": false,
      "namespace": "manual",
      "manifestPath": "/cli/manifest",
      "reason": "Manual CLI is not published yet"
    },
    "manual": {
      "enabled": true,
      "sourceId": "opensphere-manual",
      "mode": "install-time"
    },
    "search": {
      "enabled": false,
      "mode": "none",
      "reason": "Main Shell indexes the canonical Manual Registry"
    },
    "notification": {
      "enabled": false,
      "frontend": false,
      "backend": false,
      "reason": "Manual is read-only"
    },
    "observability": {
      "enabled": false,
      "logs": false,
      "metrics": false,
      "traces": false,
      "reason": "Served by the shared OAA observability plane"
    }
  }
}
